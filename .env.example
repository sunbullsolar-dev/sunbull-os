# Sunbull OS Environment Variables
# Copy to .env and fill in real values

# Database (leave empty for local SQLite)
DATABASE_URL=postgresql://user:password@host:5432/sunbull

# Auth
SECRET_KEY=change-this-to-a-random-64-char-string

# Email Notifications (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=sunbullsolar@gmail.com
SMTP_PASS=your-gmail-app-password
ADMIN_EMAIL=sunbullsolar@gmail.com
FROM_EMAIL=sunbullsolar@gmail.com
